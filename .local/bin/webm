#!/bin/bash

a="Gmail"
b="NixOS search"
c="Přehraj.to"
d="Sdílej.cz"
e="Titulky.cz"
f="Fonts"
ai="\0icon\x1fgmail"
bi="\0icon\x1fkmag"
ci="\0icon\x1fdeepin-media-player"
di="\0icon\x1fdeepin-media-player"
ei="\0icon\x1fapplication-rtf"
fi="\0icon\x1ffonts"

selected=$(echo -e "g\t$a$ai\nn\t$b$bi\np\t$c$ci\ns\t$d$di\nt\t$e$ei\nf\t$f$fi" | fuzzel --with-nth 2 --accept-nth 2 --match-nth 1 --auto-select -d )
case $selected in
    "$a")
        brave https://mail.google.com/mail/u/0/;;
    "$b")
        brave https://search.nixos.org/packages;;
    "$c")
        brave https://prehrajto.cz/;;
    "$d")
        brave https://sdilej.cz/;;
    "$e")
        brave http://titulky.com/;;
    "$f")
        brave https://www.nerdfonts.com/cheat-sheet;;
esac
