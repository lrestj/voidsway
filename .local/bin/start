#!/bin/bash

echo "#########################"
echo "#                       #"
echo "#  HOLA, VYBER SEZENÍ:  #"
echo "#  n) NIRI              #"
echo "#  s) SWAY              #"
echo "#  r) RESTARTOVAT       #"
echo "#  x) VYPNOUT           #"
echo "#                       #"
echo "#########################"
read -t 15 -n 1 -s wm_choice
case $wm_choice in
n)
exec dbus-run-session /usr/bin/niri --session
;;
s)
exec dbus-run-session sway-run
;;
x)
echo "Vypínání..."
exec loginctl poweroff
sleep 1
;;
r)
echo "Restart..."
sleep 1
exec loginctl reboot
;;
*)
echo "NEZVOLENO, SPOUŠTÍM NIRI"
sleep 1
exec dbus-run-session niri --session
;;
esac

