#!/bin/bash

a="Zamknout"
b="OdhlĂˇsit"
c="Restart"
d="Vypnout"
ai="\0icon\x1fsystem-lock-screen"
bi="\0icon\x1fsystem-log-out"
ci="\0icon\x1fsystem-reboot"
di="\0icon\x1fsystem-shutdown"

selected=$(echo -e "$a$ai\n$b$bi\n$c$ci\n$d$di" | fuzzel --config ~/.config/fuzzel/powercenter.ini --auto-select -d )
case $selected in
    "$a")
        lockscreen;;
    "$b")
        sleep 0.5; swaymsg exit;;
    "$c")
        sleep 0.5; loginctl reboot;;
    "$d")
        sleep 0.5; loginctl poweroff;;
esac
