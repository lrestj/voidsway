#!/bin/bash

a=" Vimrc"
b="Yazi.toml"
c="Waybar config"
d="Mako config"
e="Sway config"
f="Stuff2remember"
g="Configuration.nix"
h="Flake.nix"
i="Pkgs"
j="Add new script"
ai="\0icon\x1fvim"
bi="\0icon\x1fsystem-file-manager"
ci="\0icon\x1fwayland"
di="\0icon\x1fnotion"
ei="\0icon\x1fdesktop-effects"
fi="\0icon\x1fnotepad"
gi="\0icon\x1fpreferences-system-services"
hi="\0icon\x1fpreferences-system-services"
ii="\0icon\x1fpreferences-system-services"
ji="\0icon\x1fadd"

selected=$(echo -e "1\t$e$ei\n2v\t$a$ai\n3y\t$b$bi\n4w\t$c$ci\n5m\t$d$di\n6s\t$f$fi\n7c\t$g$gi\n8f\t$h$hi\n9p\t$i$ii\n0a\t$j$ji" | fuzzel --match-nth 1 --with-nth 2 --accept-nth 2 --lines 17 --auto-select -d )
case $selected in
    "$a")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.config/vim/vimrc";;
    "$b")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.config/yazi/keymap.toml";;
    "$c")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.config/waybar/config-sway.jsonc";;
    "$d")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.config/mako/config";;
    "$e")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.config/sway/config";;
    "$f")
        foot --app-id vim bash -c "sleep 0.1; exec vim ~/.dotfiles/other/stuff2remember.txt";;
    "$g")
        $TERMINAL -e vim ~/.dotfiles/nixos/hosts/zbook/configuration.nix;;
    "$h")
        $TERMINAL -e vim ~/.dotfiles/nixos/flake.nix;;
    "$i")
        $TERMINAL -e vim ~/.dotfiles/nixos/modules/pkgs.nix;;
    "$j")
        addnew
esac
